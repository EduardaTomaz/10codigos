let idade = prompt("Por favor, digite a sua idade:");

idade = parseInt(idade);

if (isNaN(idade)) {
    console.log("Por favor, digite um número válido para a idade.");
} else {
   
    if (idade >= 18) {
        console.log("Você é maior de idade.");
    } else {
        console.log("Você é menor de idade.");
    }
}
